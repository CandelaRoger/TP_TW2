generator client {
  provider        = "prisma-client-js"
  output          = "../src/prisma"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
  schemas  = ["dbo"]
}

model usuario {
  Id        Int       @id(map: "PK__Usuarios__3214EC07941D48D7") @default(autoincrement())
  Email     String    @unique(map: "UQ__Usuarios__A9D10534C25A962A") @db.VarChar(100)
  Password  String    @db.VarChar(255)
  Nombre    String    @db.VarChar(100)
  Apellido  String    @db.VarChar(100)
  Direccion String    @db.VarChar(255)
  carritos  carrito[]

  @@map("Usuarios")
  @@schema("dbo")
}

model producto {
  Id             Int              @id(map: "PK__Producto__3214EC0783CD078E") @default(autoincrement())
  Nombre         String           @db.VarChar(100)
  Descripcion    String           @db.VarChar(255)
  Clasificacion  String           @db.VarChar(100)
  Precio         Decimal          @db.Decimal(10, 2)
  DetalleCarrito DetalleCarrito[]

  @@map("Productos")
  @@schema("dbo")
}

model carrito {
  Id             Int              @id(map: "PK__Carritos__3214EC070A974E12") @default(autoincrement())
  usuarioId      Int              @map("UsuarioId")
  usuario        usuario          @relation(fields: [usuarioId], references: [Id], onUpdate: NoAction, map: "FK__Carritos__Usuari__619B8048")
  DetalleCarrito DetalleCarrito[]

  @@map("Carritos")
  @@schema("dbo")
}

model DetalleCarrito {
  Id         Int      @id(map: "PK__DetalleC__3214EC074DB22635") @default(autoincrement())
  CarritoId  Int
  ProductoId Int
  Cantidad   Int      @default(1, map: "DF__DetalleCa__Canti__6477ECF3")
  Carritos   carrito  @relation(fields: [CarritoId], references: [Id], onUpdate: NoAction, map: "FK__DetalleCa__Carri__656C112C")
  Productos  producto @relation(fields: [ProductoId], references: [Id], onUpdate: NoAction, map: "FK__DetalleCa__Produ__66603565")

  @@schema("dbo")
}
